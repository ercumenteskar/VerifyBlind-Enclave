    <script type="text/javascript">
        document.body.style.zoom = "100%"
        $("#fontPlusBtn").click(function () {
            var zoom = document.body.style.zoom.substring(0, document.body.style.zoom.length - 1)
            document.body.style.zoom = (parseInt(zoom) + 5).toString() + "%"
        });
        $("#fontMinusBtn").click(function () {
            var zoom = document.body.style.zoom.substring(0, document.body.style.zoom.length - 1)
            document.body.style.zoom = (parseInt(zoom) - 5).toString() + "%"
        });
        $('#searchForm').on('submit', function (e) {
            // validation code here
            if ($("#searchKey").val() == '') {
                e.preventDefault();
            }
        });
        jquery(document).ready(function () { init_Home(); });
    </script>
