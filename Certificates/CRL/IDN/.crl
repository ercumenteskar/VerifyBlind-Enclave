<style>    .shadow-keen{
        box-shadow: 0 0rem 1rem rgba(255, 255, 255, .5) !important;
    }

    .category-slider{
        background-color: white;  border: 1px solid var(--color-biru-tua); color: var(--color-biru-tua);
    }

    .lazy-img {
        opacity: 0;
        transition: opacity .3s ease;
    }

    .lazy-img.loaded {
        opacity: 1;
    }

    /* .category-slider:hover{
        cursor: pointer;
    } */

     /* =====================================================
   SKELETON LOADER FOR KEEN SLIDER (STABLE VERSION)
   ===================================================== */

    /* Base skeleton */
    .skeleton-card {
        position: relative;
        overflow: hidden;
        border-radius: 12px;
    }

    /* Hide real content */
    .skeleton-card * {
        background-color: #e5e7eb !important;
        color: transparent !important;
    }

    .skeleton-card img {
        opacity: 0 !important;
    }

    /* Shimmer overlay (GPU friendly) */
    .skeleton-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(255, 255, 255, 0.45),
            transparent
        );
        transform: translateX(-100%);
        animation: skeleton-shimmer 1.4s linear infinite;
        will-change: transform;
        pointer-events: none;
    }

    /* Keen optimizations */
    #news-skeleton,
    #news-skeleton .keen-slider__slide {
        backface-visibility: hidden;
        transform: translateZ(0);
        will-change: transform;
    }

    /* Optional spacing fix */
    #news-skeleton .keen-slider__slide {
        display: flex;
    }

    /* Shimmer animation */
    @keyframes skeleton-shimmer {
        to {
            transform: translateX(100%);
        }
    }

    /* FORCE HEIGHT agar sama dengan card asli */
    #news-skeleton .skeleton-card {
        height: 460px; /* sesuaikan dengan card berita */
        display: flex;
        flex-direction: column;
    }

    /* Area image */
    #news-skeleton .skeleton-img {
        height: 200px;
        flex-shrink: 0;
    }

    /* Body placeholder */
    #news-skeleton .card-body {
        flex: 1;
    }

    /* Fake text blocks agar tinggi stabil */
    #news-skeleton .card-body::before {
        content: "";
        display: block;
        height: 140px;
    }

    /* Container wajib relative */
    .news-wrapper {
        position: relative;
    }

    /* Skeleton overlay */
    #news-skeleton {
        position: absolute;
        inset: 0;
        z-index: 5;
    }

    /* Slider di bawah skeleton */
    #news-slider {
        position: relative;
        z-index: 1;
    }
    /* PENTING: jangan set width di skeleton card */
    #news-skeleton .keen-slider__slide .card {
        width: 100% !important;
    }</style>
