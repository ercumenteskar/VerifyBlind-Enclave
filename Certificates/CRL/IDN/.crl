<style>
    .imtel-loader { 
        width: 20px; 
        aspect-ratio: 1; 
        border-radius: 50%; 
        background: #fff; 
        box-shadow: 0 0 0 0 #fff4; 
        animation: l2 2s infinite linear; 
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%); 
    } 
    .imtel-loader:before, 
    .imtel-loader:after { 
        content: ""; 
        position: absolute; 
        inset: 0; 
        border-radius: inherit; 
        box-shadow: 0 0 0 0 #fff4; 
        animation: inherit; 
        animation-delay: -0.5s; 
    } 
    .imtel-loader:after { 
        animation-delay: -1s; 
    } 
    @keyframes l2 { 
        100% {box-shadow: 0 0 0 40px #fff0} 
    }
    #search-ai-result2:after {
        content:'';
        position: absolute;
        top: 100%;
        left: 50%;
        margin-left: '-25px';
        width: 0;
        height: 0;
        border-top: solid 20px rgba(255,255,255, 0.45);
        border-left: solid 20px transparent;
        border-right: solid 20px transparent;
    }

    .hero-card-btn{
        filter: opacity(1) !important;
    }

    .carousel-item .overlay-hero {
        position: absolute;
        inset: 0; /* top, right, bottom, left = 0 */
        background: rgba(0, 0, 0, 0.3); /* hitam transparan */
        z-index: 1;
    }
</style>

