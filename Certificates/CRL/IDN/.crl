<script>jQuery(function ($) {
    $("#keEvisa").click(function() {
        let posisiEvisa = $("#evisaForm").position();
        $('html').animate({
            scrollTop: posisiEvisa.top - 185,
        },
    );
    })

    $('.carousel').carousel({
        pause: "false"
    });

    var forbiddenPattern = /<\s*script.*?>.*?<\/\s*script\s*>|fetch\s*\(.*?\)|document\.cookie/gi;

    function sanitizeInput(text) {
      return text.replace(forbiddenPattern, '');
    }

    $("#search2").on("input paste", function(e) {
     
      var original = $(this).val();
      var cleaned = sanitizeInput(original);

      if (cleaned !== original) {
        $(this).val(cleaned);
      }
    });

    $("#searchbar_form").on('submit', function(e){
        e.preventDefault();
        
        questionAI = $('#search2').val()
        // alert(questionAI)
        if(forbiddenPattern.test(questionAI)) {
            e.preventDefault(); // cegah form submit
            return false;
        }

        if(questionAI == '')
            return

        if($("#search2").css('padding-left') == '12px'){
            document.activeElement.blur();
        }

        $("#sloader").remove()
        $("#search-ai-result-body").remove()
        $("#question-container").remove()

        // $("#content-ai").show()
        // // bubble style
        $("#content-ai").html('');
        $("#content-ai").append(`<div id='search-ai-result-body' class="text-white glass-effect2 ms-1 me-1 glass-hero-abu" style="height: 95% !important; border-radius: 4px; margin-top: .5rem !important;"></div>`)
        // $("#search-ai-result-body").css('height','96%')
        $("#search-ai-result-body").append(`
                <div class="imtel-loader"></div>
        `)

        // // $("#search-ai-result2-container").show( "fast" );
        showai()

        searchAnswer()
    })

    generatePopover()
    // startTypeWriter()
    run();
    
    var activeSubMenu;
    let activeSubMenuMobile = null;
    $(".menu-item-hero").on('click', function(){
        if (window.innerWidth <= 767) {
            const menuId = $(this).data('menu');
            const current = $('.sih-' + menuId);

            // klik menu yang sama → tutup
            if (activeSubMenuMobile === menuId) {
                hideMenu(current);
                activeSubMenuMobile = null;
                return;
            }

            // tutup menu sebelumnya
            if (activeSubMenuMobile !== null) {
                hideMenu($('.sih-' + activeSubMenuMobile));
            }

            showMenu(current);
            activeSubMenuMobile = menuId;

            if(menuId == 3){
                window.location.href = '/wna/daftar-visa-indonesia/golden-visa';
            }else if(menuId == 4){
                window.location.href = '/wna/daftar-visa-indonesia/global-citizen';
            }
        }else{

            const preview = $("#sub-menu-hero");
            const conai = $("#content-ai");
            
            if (preview.is(":visible")) {
                if(activeSubMenu != $(this).data("menu"))
                {
                    preview.css({ opacity: 0, transform: "scale(0.9)" });
                    setTimeout(() => preview.hide(), 400);

                    setTimeout(() => {
                        $("#sub-menu-title").text($(this).find('.title').text())
                        activeSubMenu = $(this).data("menu")
                        if($(this).data("menu") < 3){
                            genSubMenuHero(menuHero[activeSubMenu])
                        }
                        else if($(this).data("menu") == '3'){
                            genGoldenVisaContent()
                        }else if($(this).data("menu") == '4'){
                            genGlobalCitizenContent()
                        }
                        
                        closeai()
                        setTimeout(function() {
                            preview.show();
                            setTimeout(() => {
                                preview.css({ opacity: 1, transform: "scale(1)" });
                            }, 10);
                        }, isAIOpen ? 400 : 0);
                    }, 500);
                
                }
                    
            } else {
                $("#sub-menu-title").text($(this).find('.title').text())
                activeSubMenu = $(this).data("menu")
                if($(this).data("menu") < 3){
                    genSubMenuHero(menuHero[activeSubMenu])
                }
                else if($(this).data("menu") == '3'){
                    genGoldenVisaContent()
                }else if($(this).data("menu") == '4'){
                    genGlobalCitizenContent()
                }
                closeai()
                setTimeout(function() {
                    preview.show();
                    setTimeout(() => {
                        preview.css({ opacity: 1, transform: "scale(1)" });
                    }, 10);
                }, isAIOpen ? 400 : 0);
                
            }
        }
    });

    function showMenu(el, duration = 200) {
        if (el.is(':visible')) return;
        el.stop(true, true).slideDown(duration);
    }

    function hideMenu(el, duration = 200) {
        if (!el.is(':visible')) return;
        el.stop(true, true).slideUp(duration);
    }

    function genSubMenuHero(data){
        var newMenu = ``;
        for(var i = 0 ; i < data.length; i++){
            newMenu += `<li role="menuitem" onclick="window.location.href='`+data[i].link+`'">
                            <div class="left">
                                <a href="`+data[i].link+`" class="title" style="margin-bottom: 0px;">`+data[i].title+`</a>
                            </div>
                            <div class="arrow">›</div>
                        </li>`
        }
        $("#sub-menu-hero .menu").html(newMenu);
    }

    function genGoldenVisaContent(){
        $("#sub-menu-hero .menu").html(`
            <p class="text-white text-justify">`+ctnGoldenVisa+`</p>
            <ul class="menu m-0 right" role="menu" onclick="window.location.href='/wna/daftar-visa-indonesia/golden-visa'">
                <li role="menuitem">
                    <div class="left">
                        <a href="#" class="title" style="margin-bottom: 0px;">Discover Golden Visa</a>
                    </div>
                    <div class="arrow">›</div>
                </li>
            </ul>
        `)
    }

    function genGlobalCitizenContent(){
        $("#sub-menu-hero .menu").html(`
            <p class="text-white text-justify">`+ctnGlobalCitizen+`</p>
            <ul class="menu m-0 right" role="menu" onclick="window.location.href='/wna/daftar-visa-indonesia/global-citizen'">
                <li role="menuitem">
                    <div class="left">
                        <a href="#" class="title" style="margin-bottom: 0px;">Details</a>
                    </div>
                    <div class="arrow">›</div>
                </li>
            </ul>
        `)
    }

