                                <img class="h-100 object-fit-cover w-100 mb-3 lazy-img" alt="Imigrasi Soekarno Hatta Kembali Masuk 10 Besar Layanan Imigrasi Bandara Terbaik Versi Skytrax" data-src="/upload/2026/Foto%20Berita%20Artikel%20Siaran%20Pers/Imigrasi%20Soekarno%20Hatta%20Kembali%20Masuk%2010%20Besar%20Layanan%20Imigrasi%20Bandara%0ATerbaik%20Versi%20Skytrax.jpeg?width=400" style="height: 200px !important;">                                <div
                                    class="badge bg-biru-muda rounded-0 small position-absolute top-0 start-0 m-2 text-uppercase">
                                    Siaran Pers                                </div>
