<script>
    
    // Add something to given element placeholder
    function addToPlaceholder(toAdd, el) {
        el.attr('placeholder', el.attr('placeholder') + toAdd);
        // Delay between symbols "typing" 
        return new Promise(resolve => setTimeout(resolve, 100));
    }

    // Cleare placeholder attribute in given element
    function clearPlaceholder(el) {
        el.attr("placeholder", "");
    }

    // Print one phrase
    let count = 0;

    function printPhrase(phrase, el) {
        return new Promise(resolve => {
            // Clear placeholder before typing next phrase
            clearPlaceholder(el);
            let letters = phrase.split('');
            // For each letter in phrase
            letters.reduce(
                (promise, letter, index) => promise.then(_ => {
                    // Resolve promise when all letters are typed
                    if (index === letters.length - 1) {
                        // Delay before start next phrase "typing"
                        setTimeout(resolve, 1000);
                    }
                    return addToPlaceholder(letter, el);
                }),
                Promise.resolve()
            );
            count += 1;
            if (count == 4) {
                run();
                count = 0;
            }
        });
    }

    // Print given phrases to element
    function printPhrases(phrases, el) {
        phrases.reduce(
            (promise, phrase) => promise.then(_ => printPhrase(phrase, el)),
            Promise.resolve()
        );
    }

    // Start typing
    function run() {
        let phrases = [
            "Syarat Permohonan Pembuatan Paspor",
            "Alamat Kantor Imigrasi Jakarta Selatan",
            "Harga Paspor Elektronik",
            "",
        ];
        printPhrases(phrases, $('#search2'));
    }

    var menuHero = {
        0: [{"title":"Paspor Republik Indonesia","link":"/layanan-wni/paspor-republik-indonesia/permohonan-baru/masyarakat-umum/permohonan-baru/masyarakat-umum"},{"title":"Kartu Perjalanan Bisnis APEC","link":"/layanan-wni/kartu-perjalanan-pebisnis-apec"}],
        1: [{"title":"Daftar Visa Indonesia","link":"/wna/daftar-visa-indonesia"},{"title":"Daftar Subjek VoA, BVK & Calling Visa","link":"/wna/daftar-negara-voa-bvk-calling-visa"},{"title":"Izin Tinggal Keimigrasian","link":"/wna/izin-tinggal-keimigrasian"}],
        2: [{"title":"M-Paspor","link":"/faq/m-paspor"},{"title":"Affidavit","link":"/faq/affidavit"},{"title":"Izin Tinggal","link":"/faq/izin-tinggal"},{"title":"Kartu Perjalanan Pebisnis APEC","link":"/faq/kartu-perjalanan-pebisnins-apec"},{"title":"Paspor","link":"/faq/paspor"},{"title":"Pelaporan Orang Asing","link":"/faq/pelaporan-orang-asing"},{"title":"SDUWHV","link":"/faq/sduwhv"},{"title":"Visa","link":"/faq/visa"}],
    };

    var ctnGoldenVisa = "Thinking about making Indonesia your long-term home for work, study, or investment? The Golden Visa offers a pathway to residency with some special perks. It's designed for talented individuals like investors, business owners, researchers, top students, and those who've made significant humanitarian contributions or served on the front lines. You can explore the specific criteria and advantages of this visa, as well as access online resources to submit your application."
    var ctnGlobalCitizen = "Bagi diaspora dan keluarga lintas negara, Indonesia kini bukan sekadar tempat singgah, melainkan masa depan yang pasti. GCI hadir memberikan izin tinggal tetap tanpa batas waktu tanpa harus menanggalkan kewarganegaraan Anda. Dengan proses instan saat kedatangan dan sistem pelaporan minimal lima tahun sekali tanpa biaya, kami memastikan transisi hidup Anda berjalan tenang dan berkelanjutan. GCI memberikan kebebasan bagi Anda untuk pulang, menetap, dan membangun masa depan di tanah air dengan kenyamanan penuh."
</script>


