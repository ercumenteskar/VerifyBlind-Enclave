# LF-only enforcement for reproducible builds. CRLF in source files would change
# byte content → different PCR0. Linux CI runner checks out with LF; Windows
# devs editing files locally would otherwise convert to CRLF and break PCR0.
* text=auto eol=lf

# Binary files (no line-ending conversion, no diff)
*.onnx binary
*.eif binary
*.crt binary
*.crl binary
*.cer binary
*.der binary
*.key binary

# LFS
Models/w600k_mbf.onnx filter=lfs diff=lfs merge=lfs -text
